# PostgreSQL connection string
# For local dev: postgresql://USER:PASSWORD@localhost:5432/realytics
# For SQLite (quick test): change prisma/schema.prisma provider to "sqlite" and use: file:./dev.db
DATABASE_URL="postgresql://postgres:password@localhost:5432/realytics"

# OpenAI API key (for AI investment reports)
OPENAI_API_KEY="sk-your-key-here"

# NextAuth — required for user accounts feature
# Generate a strong secret: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-here"
NEXTAUTH_URL="http://localhost:3000"
